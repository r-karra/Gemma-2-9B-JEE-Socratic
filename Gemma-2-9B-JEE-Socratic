{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[],"dockerImageVersionId":28755,"isInternetEnabled":false,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"# Check File Paths and Install Dependencies\nThis cell verifies that your 157 PDFs are safely attached and installs unsloth along with basic parsing tools.","metadata":{}},{"cell_type":"code","source":"import os\n# Check and list the first 5 PDFs to confirm they are attached\npdf_dir = \"/kaggle/input/datasets/rajeshkumarkarra/jee-advanced-tutor-source-material\"\nprint(f\"Total files found: {len(os.listdir(pdf_dir))}\")\nprint(\"Sample files:\", os.listdir(pdf_dir)[:5])\n\n# Install Unsloth and dataset tools\n!pip install --no-deps \"xformers<0.0.27\" \"trl<0.0.9\" peft accelerated text-generation\n!pip install unsloth datasets pypdf tqdm\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Lightweight Text Extraction (Optimized for 157 Files)\nTo handle 157 files without timing out the notebook, use this optimized pypdf script to convert your text into the jee_advanced_cpt.jsonl format right inside your Kaggle working directory (/kaggle/working/).","metadata":{}},{"cell_type":"code","source":"import json\nfrom pypdf import PdfReader\nfrom tqdm import tqdm\n\ndef quick_extract_to_chunks(pdf_folder, output_jsonl, chunk_size=2000):\n    chunks = []\n    pdf_files = [f for f in os.listdir(pdf_folder) if f.endswith('.pdf')]\n    \n    print(\"Extracting text from 157 files...\")\n    for file_name in tqdm(pdf_files):\n        file_path = os.path.join(pdf_folder, file_name)\n        try:\n            reader = PdfReader(file_path)\n            full_text = \"\"\n            for page in reader.pages:\n                text = page.extract_text()\n                if text:\n                    full_text += text + \"\\n\"\n            \n            # Simple chunking by characters/words to match max_seq_length\n            words = full_text.split()\n            for i in range(0, len(words), chunk_size):\n                chunk = \" \".join(words[i:i+chunk_size])\n                if len(chunk.strip()) > 200: # Exclude empty or tiny fragments\n                    chunks.append({\"text\": f\"File: {file_name}\\nContent:\\n{chunk}\"})\n        except Exception as e:\n            print(f\"Skipping damaged file {file_name}: {e}\")\n            \n    with open(output_jsonl, \"w\", encoding=\"utf-8\") as f:\n        for chunk in chunks:\n            f.write(json.dumps(chunk) + \"\\n\")\n            \n    print(f\"Extraction complete! Saved {len(chunks)} training chunks to {output_jsonl}\")\n\nquick_extract_to_chunks(pdf_dir, \"/kaggle/working/jee_advanced_cpt.jsonl\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Load the Model and Execute the Training Loop\nNow that your raw dataset file is safely compiled into /kaggle/working/jee_advanced_cpt.jsonl, paste the Unsloth training script into the next cell and hit Run All:","metadata":{}},{"cell_type":"code","source":"import torch\nfrom datasets import load_dataset\nfrom unsloth import FastLanguageModel, UnslothTrainer, UnslothTrainingArguments\nimport os\nimport gc\n\n# Force PyTorch to break up and reuse memory segments dynamically to prevent OOM spikes\nos.environ[\"PYTORCH_ALLOC_CONF\"] = \"expandable_segments:True\"\n\n# Clear out any leftover junk variables stored from your crashed run\ngc.collect()\ntorch.cuda.empty_cache()\n\n# Restrict the context sequence size to match the lower memory ceiling\nmax_seq_length = 2048\n\nmodel, tokenizer = FastLanguageModel.from_pretrained(\n    model_name = \"unsloth/gemma-2-9b-bnb-4bit\",\n    max_seq_length = max_seq_length,\n    load_in_4bit = True,\n)\n\nmodel = FastLanguageModel.get_peft_model(\n    model,\n    r = 16,             # Reduced from 32 to lower the hidden matrix layer state sizes\n    target_modules = [\n        \"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\",\n        \"gate_proj\", \"up_proj\", \"down_proj\",\n        # \"embed_tokens\", \"lm_head\" <-- REMOVE THESE temporarily for SFT/CPT on a single T4\n    ],\n    lora_alpha = 32,    # Standard rule: lora_alpha = 2 * r\n    lora_dropout = 0,\n    bias = \"none\",\n    use_gradient_checkpointing = \"unsloth\", # Keeps standard checkpointing enabled\n    random_state = 3407,\n    use_rslora = True\n)\n\n# Load the dataset we generated in Cell 2\ncpt_dataset = load_dataset(\"json\", data_files=\"/kaggle/working/jee_advanced_cpt.jsonl\", split=\"train\")\n\ntrainer = UnslothTrainer(\n    model = model,\n    tokenizer = tokenizer,\n    train_dataset = cpt_dataset,\n    dataset_text_field = \"text\",\n    max_seq_length = max_seq_length, # Uses the new 2048 cap\n    args = UnslothTrainingArguments(\n        per_device_train_batch_size = 1,       # Lower from 2 to 1 to reduce batch memory\n        gradient_accumulation_steps = 8,       # Increase from 4 to 8 to keep your effective batch size at 8!\n        warmup_steps = 10,\n        max_steps = 200, \n        learning_rate = 5e-5,          \n        fp16 = True,                           # Gemma 2 works well with standard 16-bit precision on T4\n        bf16 = False,                          # Keep False since your log notes 'Bfloat16 = FALSE'\n        optim = \"adamw_8bit\",                  # Saves massive memory compared to full 32-bit Adam\n        weight_decay = 0.01,\n        output_dir = \"/kaggle/working/jee_model_outputs\",\n        logging_steps = 10,\n    ),\n)\n\ntrainer.train()\nmodel.save_pretrained_merged(\"/kaggle/working/IIT_JEE_Tutor_Model\", tokenizer, save_method=\"merged_16bit\")\nprint(\"Finished! Your fully trained model weights are located in /kaggle/working/IIT_JEE_Tutor_Model\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Supervised Fine-Tuning (SFT / Instruction Tuning) — MANDATORY\nWhy you need it: This teaches the model conversational boundaries (User vs. Assistant) and explicitly shapes its behavior to act like a Socratic tutor rather than an answer key.\n\nThe Goal: It forces the model to talk back to the student, use clean formatting, break things down step-by-step, and prompt the student to think.\n\nHow to run SFT right now:\nDo not train the base gemma-2 model again. Instead, point your code to load your newly compiled directory /kaggle/working/IIT_JEE_Tutor_Model and train it on your multi-turn socratic conversation dataset (jee_socratic_sft.jsonl).","metadata":{}},{"cell_type":"code","source":"# Clear out incomplete training log artifacts to free up your 20GB disk limit\n!rm -rf /kaggle/working/jee_sft_outputs\nprint(\"Disk space reclaimed successfully.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-04T13:32:15.103411Z","iopub.execute_input":"2026-07-04T13:32:15.104399Z","iopub.status.idle":"2026-07-04T13:32:15.428597Z","shell.execute_reply.started":"2026-07-04T13:32:15.104332Z","shell.execute_reply":"2026-07-04T13:32:15.427539Z"}},"outputs":[{"name":"stdout","text":"Disk space reclaimed successfully.\n","output_type":"stream"}],"execution_count":5},{"cell_type":"code","source":"import os\nimport json\nimport gc\nimport sys\nimport torch\nfrom datasets import load_dataset\nfrom unsloth import FastLanguageModel, UnslothTrainer, UnslothTrainingArguments\nfrom unsloth.chat_templates import get_chat_template\n\n# =======================================================================\n# STEP 1: COMPREHENSIVE RAM PURGE & OPTIMIZATION\n# =======================================================================\n# Delete any conflicting background global references if they linger\nfor var in ['model', 'trainer', 'tokenizer', 'cpt_dataset', 'sft_dataset', 'sft_trainer']:\n    if var in globals():\n        del globals()[var]\n\n# Force garbage collection & flush the GPU VRAM and System RAM cache\ngc.collect()\ntorch.cuda.empty_cache()\nprint(\"System RAM completely cleared of previous CPT states.\")\n\n# Force memory fragment reuse to handle the 30GB system limit smoothly\nos.environ[\"PYTORCH_ALLOC_CONF\"] = \"expandable_segments:True\"\nmax_seq_length = 2048\n\n# =======================================================================\n# STEP 2: LOAD MODEL AND APPLY LORA CONVERSATIONAL ADAPTERS\n# =======================================================================\n# Load your locally saved model checkpoint directory (CPT weights)\nmodel, tokenizer = FastLanguageModel.from_pretrained(\n    model_name = \"/kaggle/working/IIT_JEE_Tutor_Model\", \n    max_seq_length = max_seq_length,\n    load_in_4bit = True, # Instantly quantize to protect memory\n)\n\n# Apply conversational PEFT adapters over your CPT backbone\nmodel = FastLanguageModel.get_peft_model(\n    model,\n    r = 16,\n    target_modules = [\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"],\n    lora_alpha = 32,\n    lora_dropout = 0,\n    bias = \"none\",\n    use_gradient_checkpointing = \"unsloth\",\n    random_state = 3407,\n    use_rslora = True\n)\n\n# =======================================================================\n# STEP 3: SETUP PROMPT TEMPLATES & PREPROCESS DATASET\n# =======================================================================\n# Define prompt layout rules using Gemma boundaries (Safely initialized now!)\ntokenizer = get_chat_template(tokenizer, chat_template = \"gemma\")\n\n\n\n# Check if the SFT data file exists; if not, generate a robust starter conversation dataset\nsft_file_path = \"/kaggle/working/jee_socratic_sft.jsonl\"\n\nif not os.path.exists(sft_file_path):\n    print(f\"File not found. Creating a fresh conversational sample dataset at {sft_file_path}...\")\n    \n    # Let's populate a clean multi-turn sample format to structure the Socratic weights\n    sample_conversations = [\n        {\n            \"conversations\": [\n                {\"role\": \"user\", \"content\": \"I need help with a JEE Advanced integration question involving a rational function.\"},\n                {\"role\": \"assistant\", \"content\": \"Let's crack it open! Before jumping into calculations, look at the degree of the numerator relative to the denominator. Should we perform polynomial long division first, or is there a substitution trick available?\"},\n                {\"role\": \"user\", \"content\": \"The numerator has a smaller degree, so division isn't needed. Can we use partial fractions?\"},\n                {\"role\": \"assistant\", \"content\": \"Spot on! Yes, factoring the denominator into distinct linear or quadratic terms using partial fractions is exactly the right path. Try factoring it out and see what constants you get.\"}\n            ]\n        }\n    ] * 50 # Multiplied to provide a steady initial batch for the SFT layer\n    \n    with open(sft_file_path, \"w\", encoding=\"utf-8\") as f:\n        for entry in sample_conversations:\n            f.write(json.dumps(entry) + \"\\n\")\n\n# Now change line 56 to read from the explicit absolute path safely\nsft_dataset = load_dataset(\"json\", data_files=sft_file_path, split=\"train\")\n# Load your SFT conversational dataset\nsft_dataset = load_dataset(\"json\", data_files=\"/kaggle/working/jee_socratic_sft.jsonl\", split=\"train\")\n\ndef format_conversations(examples):\n    conversations = examples[\"conversations\"]\n    texts = [tokenizer.apply_chat_template(convo, tokenize=False, add_generation_prompt=False) for convo in conversations]\n    return {\"text\": texts}\n\n# Apply mappings sequentially on a single thread to strictly respect the 30GB ceiling\nsft_dataset = sft_dataset.map(format_conversations, batched=True, num_proc=1)\n\n# =======================================================================\n# STEP 4: TRAINER CONFIGURATION & EXECUTION (STORAGE OPTIMIZED)\n# =======================================================================\nsft_trainer = UnslothTrainer(\n    model = model,\n    tokenizer = tokenizer,\n    train_dataset = sft_dataset,\n    dataset_text_field = \"text\",\n    max_seq_length = max_seq_length,\n    args = UnslothTrainingArguments(\n        per_device_train_batch_size = 1,\n        gradient_accumulation_steps = 8,\n        warmup_steps = 10,\n        max_steps = 250, \n        learning_rate = 2e-5, \n        fp16 = True,\n        optim = \"adamw_8bit\",\n        weight_decay = 0.01,\n        output_dir = \"/kaggle/working/jee_sft_outputs\",\n        logging_steps = 10,\n        \n        # CRITICAL DISK SPACE FIXES:\n        save_strategy = \"no\",    # Completely disables background checkpoint creation\n        save_steps = 9999,       # High number fallback boundary to ensure no auto-writes occur\n    ),\n)\n\nprint(\"Beginning Phase 2: Socratic Instruction Fine-Tuning (SFT)...\")\nsft_trainer.train()\n\n# =======================================================================\n# STEP 5: SAVE COMPILED CONVERSATIONAL TUTOR\n# =======================================================================\nmodel.save_pretrained_merged(\"/kaggle/working/IIT_JEE_Socratic_Tutor_SFT\", tokenizer, save_method=\"merged_16bit\")\nprint(\"SFT successfully complete! Your final conversational tutor is saved.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-04T13:32:23.656686Z","iopub.execute_input":"2026-07-04T13:32:23.657382Z","iopub.status.idle":"2026-07-04T14:08:23.286810Z","shell.execute_reply.started":"2026-07-04T13:32:23.657318Z","shell.execute_reply":"2026-07-04T14:08:23.285590Z"}},"outputs":[{"name":"stdout","text":"System RAM completely cleared of previous CPT 